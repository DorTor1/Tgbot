# --- Обязательные ---
BOT_TOKEN=your_telegram_bot_token

# --- Админы ---
ADMIN_ID=123456789
# Несколько админов (через запятую). Если задано — используется вместо одного ADMIN_ID.
# ADMINS=111111111,222222222
# 1 — админ подтверждает заявки кнопкой и выбирает срок; 0 — подписка сразу.
REQUIRE_APPROVAL=1

# --- Срок по умолчанию (если REQUIRE_APPROVAL=0) ---
SUBSCRIPTION_DAYS=30

# Объединённая подписка (ваш nginx + агрегатор). Если задано — пользователю одна ссылка
# вместо отдельных URL с каждой панели; в сообщение добавляется краткая инструкция по клиенту.
# Без токена на конце (токен = тот же subId, что в 3x-ui).
# SUBSCRIPTION_AGGREGATOR_BASE=https://sub.example.com:2096/sub

# HTML-портал (файл index.html из репозитория). Без ?name= на конце. Если задан — в Telegram
# уходит эта ссылка с ?name=<sub_id>, а не прямой URL агрегатора (приоритетнее SUBSCRIPTION_AGGREGATOR_BASE).
# Страницу нужно отдавать своим nginx с подстановкой subscriptionShareUrlTemplate → агрегатор в index.html.
# SUBSCRIPTION_PORTAL_BASE=https://mac.example.com/Oab4HaruLF

# =============================================================
# Панели 3x-ui (по одной на каждый VPS)
# =============================================================
# Для каждого сервера укажите блок с суффиксом _1, _2, _3 и т.д.
# Пользователь получит ссылку подписки на КАЖДУЮ сконфигурированную панель
# (с одним и тем же UUID/sub_id — удобно: один конфиг в клиенте, два сервера).

# --- Сервер 1 ---
PANEL_NAME_1=Нидерланды
# URL до секретного префикса панели, БЕЗ /panel/ на конце.
PANEL_BASE_URL_1=https://host1.example.com/yourPanelPrefix1
PANEL_LOGIN_1=admin
PANEL_PASSWORD_1=your_panel_password_1
# Опционально, если автодетект subURI/subPath из панели не подходит:
# SUBSCRIPTION_BASE_URL_1=https://host1.example.com
# SUBSCRIPTION_PATH_1=customSubPath
# SUBSCRIPTION_QUERY_PARAM_1=name   # name | path | bare

# --- Сервер 2 ---
PANEL_NAME_2=Германия
PANEL_BASE_URL_2=https://host2.example.com/yourPanelPrefix2
PANEL_LOGIN_2=admin
PANEL_PASSWORD_2=your_panel_password_2
# SUBSCRIPTION_BASE_URL_2=https://host2.example.com
# SUBSCRIPTION_PATH_2=customSubPath
# SUBSCRIPTION_QUERY_PARAM_2=name

# --- Только для указанного inbound id и протокола vless ---
# VLESS_FLOW_INBOUND_ID=1
# VLESS_FLOW_VISION=xtls-rprx-vision

# =============================================================
# Legacy: одна панель без суффиксов (fallback, если _1/_2 не заданы)
# =============================================================
# PANEL_BASE_URL=https://your-3x-ui-host.example.com/yourPanelPrefix
# PANEL_LOGIN=admin
# PANEL_PASSWORD=your_panel_password
# SUBSCRIPTION_BASE_URL=
# SUBSCRIPTION_PATH=
# SUBSCRIPTION_QUERY_PARAM=name
