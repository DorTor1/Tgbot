# --- Обязательные ---
BOT_TOKEN=your_telegram_bot_token

# --- Админы ---
ADMIN_ID=123456789
# ADMINS=111111111,222222222
# 1 — админ подтверждает заявки; 0 — подписка сразу.
REQUIRE_APPROVAL=1

# --- Срок по умолчанию (если REQUIRE_APPROVAL=0) ---
SUBSCRIPTION_DAYS=30

# =============================================================
# Мастер-панель 3x-ui 3.2+ (ноды подключаются в UI панели)
# =============================================================
# API: POST /panel/api/clients/add (Bearer PANEL_API_TOKEN)
# Одна запись в .env — только мастер, не нода.

PANEL_NAME_1=Германия (мастер)
# URL входа в панель 3x-ui (для API бота)
PANEL_BASE_URL_1=https://de.example.com/yourPanelPrefix
PANEL_API_TOKEN_1=your_panel_api_token
# URL подписки: 3x-ui → Подписка → «URI обратного прокси» (часто другой путь, чем панель)
# Итоговая ссылка: {SUBSCRIPTION_BASE_URL_1}/{subId}
SUBSCRIPTION_BASE_URL_1=https://de.example.com/U8ja0R1IzZ
# Логин/пароль — только для входа в веб-UI панели. Боту достаточно API-токена
# (Settings → Security → API Token). Если токен задан, LOGIN/PASSWORD можно не указывать.
# PANEL_LOGIN_1=admin
# PANEL_PASSWORD_1=your_panel_password

# Inbound id на мастере (через запятую), включая inbound с нод:
# PANEL_INBOUND_IDS=1,2,3,4

# Telegram ID → поле tgId в карточке клиента (1 по умолчанию):
# PANEL_SET_TELEGRAM_ID=1

# Формат ссылки: {SUBSCRIPTION_BASE_URL_1}/{subId} (по умолчанию SUBSCRIPTION_QUERY_PARAM=path)
# SUBSCRIPTION_QUERY_PARAM_1=name   → ...?name=<subId> (старый формат /sub)
# SUBSCRIPTION_PATH_1=sub           → только если нужен путь /sub/ поверх BASE URL

# Альтернатива: переменные без суффикса _1
# PANEL_BASE_URL=https://...
# PANEL_API_TOKEN=...

# --- Happ (синяя ссылка «Открыть в Happ» в тексте: happ://add/…) ---
# HAPP_DEEPLINK=0 — не показывать ссылку Happ
