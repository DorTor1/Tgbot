BOT_TOKEN=your_telegram_bot_token
PANEL_LOGIN=admin
PANEL_PASSWORD=your_panel_password
ADMIN_ID=123456789
# Несколько админов (через запятую). Если задано — используется вместо одного ADMIN_ID.
# ADMINS=111111111,222222222
# Подтверждение заявок на доступ (1 — ждать кнопку у админа, 0 — сразу создавать клиентов)
REQUIRE_APPROVAL=1
# URL до секретного префикса включительно, без /panel/ на конце.
# Пример: https://host.com/AbCdEfGh12 — логин POST .../AbCdEfGh12/login, API .../AbCdEfGh12/panel/api/...
PANEL_BASE_URL=https://your-3x-ui-host.example.com/yourPanelPrefix
# Опционально: если подписка отдаётся с корня домена без префикса панели.
# Если не задано, берётся только scheme://host из PANEL_BASE_URL.
# SUBSCRIPTION_BASE_URL=https://your-3x-ui-host.example.com
# Если подписка только с секретным префиксом:
# SUBSCRIPTION_BASE_URL=https://your-3x-ui-host.example.com/yourPanelPrefix
# Путь подписки и параметр subId (как в URL портала 3x-ui, напр. .../AbCd12?name=xxx)
SUBSCRIPTION_PATH=yourSubPathFromPanel
# Обычно name; для старого формата без имени параметра: bare
SUBSCRIPTION_QUERY_PARAM=name
# Срок клиента в 3x-ui (expiryTime), дней с момента выдачи
SUBSCRIPTION_DAYS=30
# Только для указанного inbound id и протокола vless:
# VLESS_FLOW_INBOUND_ID=1
# VLESS_FLOW_VISION=xtls-rprx-vision
