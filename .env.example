# --- Обязательные ---
BOT_TOKEN=your_telegram_bot_token

# --- Админы (для /send, /stats, /user_info) ---
ADMIN_ID=123456789
# ADMINS=111111111,222222222

# --- Срок по умолчанию (если в БД нет записи) ---
SUBSCRIPTION_DAYS=30

# --- Юридические документы ---
# URL страницы с публичной офертой и пользовательским соглашением
# на вашем сайте (обязательно для ЮKassa). Если пусто — в боте
# показывается полный текст из vpn_legal.py.
OFFER_URL=https://de.example.com/site_VPN_Legal/

# =============================================================
# ЮKassa (обязательно для приёма платежей)
# =============================================================
# shopId и секретный ключ из ЛК ЮKassa → Настройки → API
# Для тестов используйте тестовые ключи и shopId (test_*)
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Куда ЮKassa вернёт пользователя после оплаты.
# Рекомендуется: ссылка на вашего бота в Telegram.
YOOKASSA_RETURN_URL=https://t.me/your_bot_username

# URL вебхука: на него ЮKassa шлёт уведомления о платежах.
# Должен быть доступен извне (HTTPS). Запускается webhook.py.
YOOKASSA_WEBHOOK_URL=https://your-domain.example.com/yookassa/notify
YOOKASSA_WEBHOOK_HOST=0.0.0.0
YOOKASSA_WEBHOOK_PORT=8080

# --- Безопасность webhook (C4 + C5) ---
# 0 (по умолчанию) — webhook принимает любой POST с event=payment.succeeded.
#     ВКЛЮЧИТЕ ОБЯЗАТЕЛЬНО В ПРОДЕ, иначе любой, кто знает URL и yookassa_payment_id,
#     может выписать себе подписку поддельным webhook'ом.
# 1 — webhook проверяет (а) IP отправителя по whitelist ЮKassa, и
#     (б) HMAC-SHA256 подпись тела через Content-Signature.
#     Список IP — из https://yookassa.ru/developers/using-api/webhooks.
#     При подозрительных срабатываниях — выставьте 0, чтобы отключить.
YOOKASSA_REQUIRE_SIGNATURE=0

# 0 (по умолчанию) — проверять IP из request.remote (TCP-клиент aiohttp).
#     Используйте, если ЮKassa стучится напрямую (без прокси).
# 1 — брать реальный IP из X-Forwarded-For (первое значение).
#     Используйте, если перед webhook'ом стоит nginx/cloudflared.
#     Включайте ТОЛЬКО если ваш прокси корректно прокидывает X-Forwarded-For
#     (nginx делает это по умолчанию через `proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;`).
YOOKASSA_TRUST_PROXY=0

# --- Цены тарифов (в рублях, без копеек) ---
# Если не задано — берётся дефолт из payments.DEFAULT_PLAN_PRICES
# PLAN_PRICE_7=350
# PLAN_PRICE_30=800
# PLAN_PRICE_90=2100
# PLAN_PRICE_180=3800
# PLAN_PRICE_365=6800

# --- Чеки 54-ФЗ ---
# 0 (по умолчанию) — вы самозанятый: чеки выдаёте через «Мой налог»,
#     в API ЮKassa поле `receipt` НЕ передаётся.
# 1 — вы ИП/ООО с онлайн-кассой: чек обязателен, в API передаётся
#     `receipt` с `customer.email` (email нужно спрашивать у юзера в боте).
YOOKASSA_SEND_RECEIPT=0

# =============================================================
# Мастер-панель 3x-ui 3.2+ (ноды подключаются в UI панели)
# =============================================================
# API: POST /panel/api/clients/add (Bearer PANEL_API_TOKEN)
# Одна запись в .env — только мастер, не нода.

PANEL_NAME_1=Германия (мастер)
# URL входа в панель 3x-ui (для API бота)
PANEL_BASE_URL_1=https://de.example.com/yourPanelPrefix
PANEL_API_TOKEN_1=your_panel_api_token
# URL подписки: 3x-ui → Подписка → «URI обратного прокси» (часто другой путь, чем панель)
# Итоговая ссылка: {SUBSCRIPTION_BASE_URL_1}/{subId}
SUBSCRIPTION_BASE_URL_1=https://de.example.com/U8ja0R1IzZ
# Логин/пароль — только для входа в веб-UI панели. Боту достаточно API-токена
# (Settings → Security → API Token). Если токен задан, LOGIN/PASSWORD можно не указывать.
# PANEL_LOGIN_1=admin
# PANEL_PASSWORD_1=your_panel_password

# Inbound id на мастере (через запятую), включая inbound с нод:
# PANEL_INBOUND_IDS=1,2,3,4

# Telegram ID → поле tgId в карточке клиента (1 по умолчанию):
# PANEL_SET_TELEGRAM_ID=1

# Формат ссылки: {SUBSCRIPTION_BASE_URL_1}/{subId} (по умолчанию SUBSCRIPTION_QUERY_PARAM=path)
# SUBSCRIPTION_QUERY_PARAM_1=name   → ...?name=<subId> (старый формат /sub)
# SUBSCRIPTION_PATH_1=sub           → только если нужен путь /sub/ поверх BASE URL

# Альтернатива: переменные без суффикса _1
# PANEL_BASE_URL=https://...
# PANEL_API_TOKEN=...