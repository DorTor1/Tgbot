# --- Обязательные ---
BOT_TOKEN=your_telegram_bot_token
PANEL_LOGIN=admin
PANEL_PASSWORD=your_panel_password
# URL до секретного префикса панели включительно, БЕЗ /panel/ на конце.
# Пример: https://host.com/AbCdEfGh12 → логин POST .../AbCdEfGh12/login,
# API .../AbCdEfGh12/panel/api/...
PANEL_BASE_URL=https://your-3x-ui-host.example.com/yourPanelPrefix

# --- Админы ---
ADMIN_ID=123456789
# Несколько админов (через запятую). Если задано — используется вместо одного ADMIN_ID.
# ADMINS=111111111,222222222
# 1 — админ подтверждает заявки кнопкой и выбирает срок; 0 — подписка сразу.
REQUIRE_APPROVAL=1

# --- Срок по умолчанию (если REQUIRE_APPROVAL=0) ---
SUBSCRIPTION_DAYS=30

# --- Подписка (всё опционально) ---
# По умолчанию бот сам читает настройки подписки из панели (subURI/subPath).
# Переопределите вручную, только если автодетект не подходит.
# SUBSCRIPTION_BASE_URL=https://your-3x-ui-host.example.com
# SUBSCRIPTION_PATH=customSubPath
# Формат ссылки: name → ?name=<subId>; path → /<subId>; bare → ?<subId>.
# SUBSCRIPTION_QUERY_PARAM=name

# --- Только для указанного inbound id и протокола vless ---
# VLESS_FLOW_INBOUND_ID=1
# VLESS_FLOW_VISION=xtls-rprx-vision
